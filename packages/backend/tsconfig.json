{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "./dist/backend",
        "rootDir": "./src",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "target": "es2023",
        "strict": true,
        "esModuleInterop": true,
        "ignoreDeprecations": "6.0",
        "noEmit": false,
        "types": [
            "node"
        ]
    },
    "include": [
        "src/**/*"
    ]
}